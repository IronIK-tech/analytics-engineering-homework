select * from hr.employees;
select * from hr.jobs;
select * from hr.departments;
select * from hr.countries;
select * from hr.job_history;
select * from hr.locations;
select * from hr.regions;
--1
SELECT first_name, last_name
FROM hr.employees
WHERE manager_id = 101;
--2
select employees.first_name, employees.last_name, salary
    FROM hr.employees
WHERE salary < 4000;
--3
SELECT *
FROM hr.employees
WHERE hire_date BETWEEN '1996-01-01' AND '1996-12-31';
--4
SELECT table_name, column_name
FROM information_schema.columns
WHERE table_schema = 'hr'
AND column_name LIKE '%email%';
--5
SELECT *
FROM hr.employees
WHERE email LIKE '%example.com';
--6
SELECT *
FROM hr.employees
WHERE department_id = 20 OR department_id = 30;
--7
SELECT *
FROM hr.employees
WHERE first_name LIKE '%a';
--8
SELECT *
FROM hr.employees
WHERE salary > 6000 AND commission_pct = 0.15;
--9
SELECT *
FROM hr.employees
WHERE phone_number LIKE '515%';
--10
SELECT *
FROM hr.employees
WHERE department_id = 20
ORDER BY salary DESC;
--11
SELECT *
FROM hr.employees
ORDER BY hire_date ASC
LIMIT 7;
--12
select *
FROM hr.employees
WHERE salary > 4000
LIMIT 5;
--13
SELECT first_name, last_name,
CONCAT(salary, ' EUR') AS salary_eur
FROM hr.employees;
--14
SELECT *
FROM hr.employees
WHERE manager_id = 101
ORDER BY last_name ASC;
--15
SELECT*
FROM hr.employees
ORDER BY salary
OFFSET 3
LIMIT 10;
--16
SELECT *
FROM hr.employees
WHERE hire_date > '2000-01-01'
ORDER BY hire_date DESC;
--17
SELECT AVG(salary)
FROM hr.employees
WHERE job_id LIKE'S%';
--18
SELECT department_id,
MIN(salary), MAX(salary)
FROM hr.employees
GROUP BY department_id;
--19
SELECT
COUNT(*)
FROM hr.employees
WHERE salary > 3000;
--20
SELECT department_id,
SUM(salary)
FROM hr.employees
GROUP BY department_id
HAVING SUM(salary)> 10000;
--21
SELECT first_name,
COALESCE(NULL, 0) as commission_pct
FROM hr.employees;
--22
SELECT e.first_name, e.last_name, j.job_title
FROM hr.employees e
LEFT JOIN hr.jobs j ON e.job_id = j.job_id
--23
SELECT e.first_name, e.last_name, j.job_title
FROM hr.employees e
LEFT JOIN hr.jobs j ON e.job_id = j.job_id
WHERE salary >5000;
--24
SELECT e.first_name, e.last_name, h.department_id
FROM hr.employees e
LEFT JOIN  hr.departments h ON e.department_id = h.department_id;
--25
SELECT h.department_name, e.first_name, e.last_name
FROM hr.departments h
LEFT JOIN hr.employees e ON e.department_id = h.department_id;
--26
SELECT e.first_name, e.last_name, d.department_name
FROM hr.employees e
FULL JOIN hr.departments d ON e.department_id = d.department_id;
--27
SELECT e.first_name, e.last_name, j.job_title, d.department_name
FROM hr.employees e
LEFT JOIN hr.jobs j ON e.job_id = j.job_id
LEFT JOIN hr.departments d ON e.department_id = d.department_id;
--28
SELECT d.department_name, COUNT(*) AS employee_count
FROM hr.employees e
LEFT JOIN hr.departments d ON e.department_id = d.department_id
GROUP BY d.department_name
ORDER BY employee_count DESC;
--29
SELECT d.department_name, COUNT(e.employee_id) AS employee_count
FROM hr.employees e
LEFT JOIN hr.departments d ON e.department_id = d.department_id
GROUP BY d.department_name
HAVING COUNT(e.employee_id) > 3;
--30
SELECT d.department_name, c.country_name
FROM hr.departments d
LEFT JOIN hr.locations l ON d.location_id = l.location_id
LEFT JOIN hr.countries c ON l.country_id = c.country_id;
--31
SELECT e.first_name, e.last_name
FROM hr.employees e
LEFT JOIN hr.departments d ON e.department_id = d.department_id
LEFT JOIN hr.locations l ON d.location_id = l.location_id
LEFT JOIN hr.countries c ON l.country_id = c.country_id
LEFT JOIN hr.regions r ON c.region_id = r.region_id
WHERE r.region_name = 'Europe';
--32
SELECT first_name, last_name, salary
FROM hr.employees
WHERE salary >
      (SELECT AVG(salary)
       FROM hr.employees);
--33
SELECT department_id, dept_salary
FROM (
    SELECT department_id, SUM(salary) AS total_salary
    FROM hr.employees
    GROUP BY department_id
) AS dept_salary
WHERE total_salary > 100000;
--34
SELECT e.first_name, e.last_name
FROM hr.employees e
WHERE e.department_id IN (
    SELECT d.department_id
    FROM hr.departments d
    WHERE d.location_id IN (
        SELECT l.location_id
        FROM hr.locations l
        WHERE l.city LIKE 'S%'
    )
);
--35
SELECT e.first_name, e.last_name, e.salary, e.job_id
FROM hr.employees e
WHERE e.salary > (
    SELECT j.max_salary
    FROM hr.jobs j
    WHERE j.job_id = e.job_id
);
SELECT e.first_name, e.last_name, e.salary, j.min_salary, j.max_salary
FROM hr.employees e
LEFT JOIN hr.jobs j ON e.job_id = j.job_id
ORDER BY e.salary DESC;
--37
SELECT department_name
FROM hr.departments
WHERE department_id NOT IN (
    SELECT DISTINCT department_id
    FROM hr.employees
    WHERE department_id IS NOT NULL
);
--38
SELECT COUNT(*) AS employee_count
FROM hr.employees
WHERE department_id IN (
    SELECT department_id
    FROM hr.employees
    GROUP BY department_id
    HAVING AVG(salary) > 15000
);

